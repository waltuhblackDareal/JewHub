-- Tab Logic
local Pages = {}
local function CreateTab(name, order)
    local TabBtn = Instance.new("TextButton", SideBar)
    TabBtn.Name = name .. "Btn"
    TabBtn.LayoutOrder = order
    TabBtn.Size = UDim2.new(0.9, 0, 0, 32)
    TabBtn.BackgroundColor3 = Color3.fromRGB(0, 56, 184) -- Blauw passend bij vlag
    TabBtn.Font = Enum.Font.FredokaOne
    TabBtn.Text = name:upper()
    TabBtn.TextColor3 = Color3.new(1, 1, 1) -- WITTE TEKST
    TabBtn.TextSize = 10
    TabBtn.ZIndex = 6
    Instance.new("UICorner", TabBtn)
    
    local RedStroke = Instance.new("UIStroke", TabBtn)
    RedStroke.Color = Color3.fromRGB(255, 0, 0)
    RedStroke.Thickness = 3
    
    local Indicator = Instance.new("Frame", TabBtn)
    Indicator.Name = "Indicator"
    Indicator.Size = UDim2.new(0, 8, 1, 0)
    Indicator.Position = UDim2.new(0, -5, 0, 0)
    Indicator.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    Indicator.Visible = false
    Indicator.ZIndex = 7
    Instance.new("UICorner", Indicator)

    local Page = Instance.new("Frame", ContentFrame)
    Page.Name = name .. "Page"
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ZIndex = 6
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        for _, b in pairs(SideBar:GetChildren()) do 
            if b:IsA("TextButton") then b.Indicator.Visible = false end 
        end
        Page.Visible = true
        Indicator.Visible = true
    end)
    Pages[name] = Page
    return Page
end

