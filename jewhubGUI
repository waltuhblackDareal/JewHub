-- Styled Input Helper (Voor Movement)
local function AddStyledInput(parent, labelText, placeholder, yPos, bgColor)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Text = labelText
    lbl.Font = Enum.Font.FredokaOne
    lbl.TextSize = 18
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.Position = UDim2.new(0.1, 0, yPos, -25)
    lbl.Size = UDim2.new(0.8, 0, 0, 20)
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 10
    Instance.new("UIStroke", lbl).Color = Color3.new(1,0,0)

    local inp = Instance.new("TextBox", parent)
    inp.PlaceholderText = placeholder
    inp.PlaceholderColor3 = Color3.fromRGB(200, 200, 200)
    inp.Position = UDim2.new(0.1, 0, yPos, 0)
    inp.Size = UDim2.new(0.8, 0, 0, 35)
    inp.BackgroundColor3 = bgColor
    inp.TextColor3 = Color3.new(1, 1, 1) -- WITTE TEKST
    inp.Font = Enum.Font.FredokaOne
    inp.TextSize = 18
    inp.Text = ""
    inp.ZIndex = 10
    Instance.new("UICorner", inp)
    local st = Instance.new("UIStroke", inp)
    st.Color = Color3.new(1,0,0)
    st.Thickness = 4
    return inp
end

