-- Script Logic
local function apply()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then
        if tonumber(SpeedInp.Text) then hum.WalkSpeed = tonumber(SpeedInp.Text) end
        if tonumber(JumpInp.Text) then hum.UseJumpPower = true hum.JumpPower = tonumber(JumpInp.Text) end
    end
end
SpeedInp.FocusLost:Connect(function(e) if e then apply() end end)
JumpInp.FocusLost:Connect(function(e) if e then apply() end end)

